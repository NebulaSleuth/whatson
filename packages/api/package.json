{
  "name": "@whatson/api",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "service:install": "tsx src/service.ts install",
    "service:uninstall": "tsx src/service.ts uninstall",
    "service:status": "tsx src/service.ts status"
  },
  "dependencies": {
    "@whatson/shared": "*",
    "express": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "node-cache": "^5.1.2",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0"
  }
}
