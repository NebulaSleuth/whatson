{
  "name": "@whatson/api",
  "version": "0.1.37",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "service:install": "tsx src/service.ts install",
    "service:uninstall": "tsx src/service.ts uninstall",
    "service:status": "tsx src/service.ts status",
    "build:standalone": "node scripts/build-standalone.js",
    "build:standalone:bundle-only": "node scripts/build-standalone.js --skip-sea",
    "build:installer": "node scripts/build-standalone.js && node scripts/create-installer.js"
  },
  "dependencies": {
    "@whatson/shared": "*",
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.1.0",
    "jimp": "^1.6.1",
    "node-cache": "^5.1.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0"
  }
}
