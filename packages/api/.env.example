# Server
PORT=3001

# Plex Media Server
# ─────────────────────────────────────────────────────────────────
# Option A (Remote / Auto-discover):
#   Leave PLEX_URL empty. The backend will use your token to discover
#   your server via plex.tv and connect using the best available
#   connection (remote HTTPS preferred, falls back to local).
#   Just provide your token:
#
#   PLEX_URL=
#   PLEX_TOKEN=your_plex_token_here
#
# Option B (Direct / Local):
#   Set PLEX_URL to your server's address directly:
#
#   PLEX_URL=http://192.168.1.100:32400
#   PLEX_TOKEN=your_plex_token_here
#
# To find your token:
#   Plex Web → any item → Get Info → View XML → copy X-Plex-Token from URL
# ─────────────────────────────────────────────────────────────────
PLEX_URL=
PLEX_TOKEN=your_plex_token_here

# Sonarr (TV Shows)
# URL: Local (http://192.168.1.100:8989) or public remote URL
# API Key: Sonarr UI → Settings → General → Security → API Key
SONARR_URL=http://192.168.1.100:8989
SONARR_API_KEY=your_sonarr_api_key_here

# Radarr (Movies)
# URL: Local (http://192.168.1.100:7878) or public remote URL
# API Key: Radarr UI → Settings → General → Security → API Key
RADARR_URL=http://192.168.1.100:7878
RADARR_API_KEY=your_radarr_api_key_here

# EPG / Live TV
# Provider: tvmaze (free, no key needed), tmdb (requires API key), or xmltv
# Country: ISO country code for TV schedule (US, GB, CA, AU, etc.)
# TMDB API Key: Register free at https://www.themoviedb.org/settings/api
EPG_PROVIDER=tvmaze
EPG_COUNTRY=US
TMDB_API_KEY=your_tmdb_api_key_here
