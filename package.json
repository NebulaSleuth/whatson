{
  "name": "whatson",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w packages/api",
    "dev:mobile": "npm run start -w apps/mobile",
    "build:api": "npm run build -w packages/api",
    "build:shared": "npm run build -w packages/shared",
    "build:standalone": "npm run build:standalone -w packages/api",
    "build:installer": "npm run build:installer -w packages/api",
    "service:install": "npm run service:install -w packages/api",
    "service:uninstall": "npm run service:uninstall -w packages/api",
    "service:status": "npm run service:status -w packages/api",
    "roku:deploy": "npm run deploy -w apps/roku",
    "roku:package": "npm run package -w apps/roku",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "~5.7.0",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "react-native-web": "~0.19.13",
    "react": "19.1.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "version": "1.0.0"
}
