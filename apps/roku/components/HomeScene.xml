<?xml version="1.0" encoding="utf-8" ?>
<!--
  Root scene. Owns three views and routes between them via visibility +
  focus toggling. No scene stack — simpler state machine while we build
  out the channel.
-->
<component name="HomeScene" extends="Scene">
    <script type="text/brightscript" uri="HomeScene.brs" />

    <interface>
        <field id="apiUrl" type="string" />
    </interface>

    <children>
        <Rectangle width="1920" height="1080" color="0x0e0e0eff" />

        <!-- ─── Home view: title + RowList of shelves ─── -->
        <Group id="homeView">
            <Label
                id="title"
                text="Whats On"
                translation="[80, 60]"
                font="font:LargeBoldSystemFont"
                color="0xe5a00dff" />

            <Label
                id="status"
                text="Loading…"
                translation="[80, 130]"
                color="0xb0b0b0ff" />

            <RowList
                id="rowList"
                translation="[80, 200]"
                itemSize="[1760, 360]"
                rowItemSize="[[200, 300]]"
                rowItemSpacing="[[16, 0]]"
                rowSpacing="[40]"
                rowFocusAnimationStyle="floatingFocus"
                rowLabelOffset="[[0, 0]]"
                showRowLabel="[true]"
                visible="false"
                focusable="true" />
        </Group>

        <!-- ─── Detail view: hero + metadata + actions ─── -->
        <Group id="detailView" visible="false">
            <Poster
                id="detailBackdrop"
                width="1920"
                height="1080"
                opacity="0.4"
                loadDisplayMode="scaleToFill" />

            <Rectangle width="1920" height="1080" color="0x000000aa" />

            <Label
                id="detailTitle"
                translation="[120, 200]"
                width="1300"
                font="font:LargeBoldSystemFont"
                color="0xffffffff" />

            <Label
                id="detailSubtitle"
                translation="[120, 280]"
                width="1300"
                font="font:MediumBoldSystemFont"
                color="0xc0c0c0ff" />

            <Label
                id="detailMeta"
                translation="[120, 340]"
                width="1300"
                color="0xa0a0a0ff" />

            <Label
                id="detailSummary"
                translation="[120, 400]"
                width="1300"
                wrap="true"
                maxLines="6"
                color="0xe0e0e0ff" />

            <LayoutGroup
                id="detailActions"
                translation="[120, 720]"
                layoutDirection="horiz"
                itemSpacings="[24]">
                <Button id="playButton" text="Play" minWidth="240" />
                <Button id="backButton" text="Back" minWidth="240" />
            </LayoutGroup>
        </Group>

        <!-- ─── Player view: fullscreen Video ─── -->
        <Group id="playerView" visible="false">
            <Video id="video" width="1920" height="1080" />
        </Group>
    </children>
</component>
