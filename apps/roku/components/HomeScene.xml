<?xml version="1.0" encoding="utf-8" ?>
<!--
  Root scene. Owns three views and routes between them via visibility +
  focus toggling. No scene stack — simpler state machine while we build
  out the channel.
-->
<component name="HomeScene" extends="Scene">
    <script type="text/brightscript" uri="HomeScene.brs" />
    <!-- source/ files aren't auto-included in component threads — pull
         Config.brs in explicitly so configApiUrl() is callable from init(). -->
    <script type="text/brightscript" uri="pkg:/source/Config.brs" />

    <interface>
        <field id="apiUrl" type="string" />
    </interface>

    <children>
        <Rectangle width="1920" height="1080" color="0x0e0e0eff" />

        <!-- Surface strip behind the tab bar — matches mobile's
             tabBarStyle.backgroundColor (#1A1A1A) with a 1px
             cardBorder line at the bottom edge (#2A2A2A). 92px tall
             so the 80px buttons sit with 6px of breathing room above
             AND below; the gap between the border and the content
             below (which stays at y=120) shrinks to compensate, so
             nothing else moves. -->
        <Rectangle
            id="tabBarSurface"
            width="1920"
            height="92"
            translation="[0, 0]"
            color="0x1a1a1aff" />
        <Rectangle
            id="tabBarBorder"
            width="1920"
            height="1"
            translation="[0, 92]"
            color="0x2a2a2aff" />

        <!-- Brand mark — top-left, kept above (not in) the tab bar
             since the mobile tab bar has no brand. Hidden views can
             still toggle it via showChrome. -->
        <Label
            id="title"
            text="Whats On"
            translation="[80, 70]"
            visible="false"
            font="font:MediumBoldSystemFont"
            color="0xe5a00dff" />

        <!-- Real-time clock — overlays the right edge of the tab
             bar strip (matches the mobile Clock overlay top-right).
             Shifted down 6px to stay vertically centered after the
             tab bar grew from 80 to 92px tall. -->
        <Label
            id="clockLabel"
            translation="[1700, 32]"
            width="160"
            horizAlign="right"
            font="font:MediumBoldSystemFont"
            color="0xffffffff" />

        <!-- ─── Tab bar ───
             Custom TabButton components (icon-above-text, gold
             bottom-border focus indicator). Roku's built-in Button
             only supports inline icons and a rectangular focus
             bitmap, so the mobile look requires this custom node. -->
        <LayoutGroup
            id="tabBar"
            translation="[80, 6]"
            layoutDirection="horiz"
            itemSpacings="[8]">
            <TabButton id="tabHome" label="Home" iconFocused="◉" iconUnfocused="○" focusable="true" />
            <TabButton id="tabTv" label="TV Shows" iconFocused="▣" iconUnfocused="□" focusable="true" />
            <TabButton id="tabMovies" label="Movies" iconFocused="▶" iconUnfocused="▷" focusable="true" />
            <TabButton id="tabSports" label="Sports" iconFocused="◆" iconUnfocused="◇" focusable="true" />
            <TabButton id="tabLibrary" label="Library" iconFocused="▤" iconUnfocused="▤" focusable="true" />
            <TabButton id="tabSearch" label="Search" iconFocused="⦿" iconUnfocused="◎" focusable="true" />
            <TabButton id="tabSettings" label="Settings" iconFocused="⚙" iconUnfocused="⚙" iconFontUri="pkg:/fonts/NotoSansSymbols.ttf" iconYOffset="-6" focusable="true" />
        </LayoutGroup>

        <!-- ─── Home view: status + RowList of shelves ─── -->
        <Group id="homeView">
            <Label
                id="status"
                text="Loading…"
                translation="[80, 100]"
                color="0xb0b0b0ff" />

            <!-- numRows is the magic field — without it RowList renders
                 one row at a time. floatingFocus keeps the focused
                 row's brand styling. itemSize / rowItemSize tuned so
                 three shelves fit comfortably on 1080p. -->
            <RowList
                id="rowList"
                translation="[80, 120]"
                itemSize="[1760, 400]"
                numRows="2"
                rowItemSize="[[220, 330]]"
                rowItemSpacing="[[16, 0]]"
                rowSpacings="[20, 20, 20, 20, 20, 20, 20, 20]"
                vertFocusAnimationStyle="floatingFocus"
                rowFocusAnimationStyle="floatingFocus"
                rowLabelOffset="[[0, 0]]"
                showRowLabel="[true]"
                focusBitmapBlendColor="0x00000000"
                focusFootprintBlendColor="0x00000000"
                visible="false"
                focusable="true" />
        </Group>

        <!-- ─── TV Shows view: filtered home shelves (Downloading /
             Ready to Watch / Coming Soon / Tracked). Mirrors the
             mobile (tabs)/tv.tsx — same shelves, same source feeds. -->
        <Group id="tvView" visible="false">
            <Label
                id="tvStatus"
                text="Loading TV…"
                translation="[80, 100]"
                color="0xb0b0b0ff" />

            <RowList
                id="tvRowList"
                translation="[80, 120]"
                itemSize="[1760, 400]"
                numRows="2"
                rowItemSize="[[220, 330]]"
                rowItemSpacing="[[16, 0]]"
                rowSpacings="[20, 20, 20, 20, 20, 20, 20, 20]"
                vertFocusAnimationStyle="floatingFocus"
                rowFocusAnimationStyle="floatingFocus"
                rowLabelOffset="[[0, 0]]"
                showRowLabel="[true]"
                focusBitmapBlendColor="0x00000000"
                focusFootprintBlendColor="0x00000000"
                visible="false"
                focusable="true" />
        </Group>

        <!-- ─── Movies view: filtered home shelves (Downloading /
             Ready to Watch / Coming Soon). Mirrors mobile
             (tabs)/movies.tsx. -->
        <Group id="moviesView" visible="false">
            <Label
                id="moviesStatus"
                text="Loading movies…"
                translation="[80, 100]"
                color="0xb0b0b0ff" />

            <RowList
                id="moviesRowList"
                translation="[80, 120]"
                itemSize="[1760, 400]"
                numRows="2"
                rowItemSize="[[220, 330]]"
                rowItemSpacing="[[16, 0]]"
                rowSpacings="[20, 20, 20, 20, 20, 20, 20, 20]"
                vertFocusAnimationStyle="floatingFocus"
                rowFocusAnimationStyle="floatingFocus"
                rowLabelOffset="[[0, 0]]"
                showRowLabel="[true]"
                focusBitmapBlendColor="0x00000000"
                focusFootprintBlendColor="0x00000000"
                visible="false"
                focusable="true" />
        </Group>

        <!-- ─── Library view: type + source toggles + library grid ─── -->
        <Group id="libraryView" visible="false">
            <!-- Two-button TV / Movies toggle, mirroring the mobile
                 library tab. Selection swaps the dataset feeding the
                 grid below. -->
            <LayoutGroup
                id="libraryTypeToggle"
                translation="[80, 110]"
                layoutDirection="horiz"
                itemSpacings="[8]">
                <TabButton id="libraryTypeShow" label="TV Shows" hideIcon="true" focusable="true" />
                <TabButton id="libraryTypeMovie" label="Movies" hideIcon="true" focusable="true" />
            </LayoutGroup>

            <!-- Source filter: All / Plex / Jellyfin / Emby. Mirrors
                 the web Library page pills. "All" unions every
                 configured library server; the other pills filter to
                 a single source. -->
            <LayoutGroup
                id="librarySourceToggle"
                translation="[80, 200]"
                layoutDirection="horiz"
                itemSpacings="[8]">
                <TabButton id="librarySourceAll"      label="All"      hideIcon="true" buttonWidth="140" focusable="true" />
                <TabButton id="librarySourcePlex"     label="Plex"     hideIcon="true" buttonWidth="140" focusable="true" />
                <TabButton id="librarySourceJellyfin" label="Jellyfin" hideIcon="true" buttonWidth="140" focusable="true" />
                <TabButton id="librarySourceEmby"     label="Emby"     hideIcon="true" buttonWidth="140" focusable="true" />
            </LayoutGroup>

            <Label
                id="libraryStatus"
                text="Loading library…"
                translation="[80, 290]"
                color="0xb0b0b0ff" />

            <!-- itemComponentName tells MarkupGrid which custom component
                 to render per cell. Without it MarkupGrid can't create
                 children at all (Roku logs "Failed to create markup
                 item"). PosterItem renders a poster + title label. -->
            <MarkupGrid
                id="libraryGrid"
                itemComponentName="PosterItem"
                translation="[80, 290]"
                itemSize="[220, 400]"
                itemSpacing="[16, 24]"
                numRows="2"
                numColumns="7"
                vertFocusAnimationStyle="floatingFocus"
                focusBitmapBlendColor="0x00000000"
                focusFootprintBlendColor="0x00000000"
                visible="false"
                focusable="true" />
        </Group>

        <!-- ─── Search view ─────────────────────────────────────────
             Mirrors mobile (tabs)/search.tsx. v1 ships library search
             only — Discover & Track requires Sonarr/Radarr add modals
             which we'll build alongside the detail-sheet "Add to..."
             actions in a follow-up. The search button doubles as the
             input display: pressing it opens a KeyboardDialog modal,
             results land in the MarkupGrid below. -->
        <Group id="searchView" visible="false">
            <TabButton
                id="searchInputButton"
                label="Tap to search your library…"
                hideIcon="true"
                buttonWidth="1200"
                translation="[80, 100]"
                focusable="true" />

            <!-- Mode toggle — Library searches the user's
                 plex/jellyfin/emby content via /api/search; Discover
                 searches TMDB via /api/discover/search and lets you
                 Track or Add to Sonarr/Radarr. Same chip pattern as
                 mobile (tabs)/search.tsx. -->
            <LayoutGroup
                id="searchModeToggle"
                translation="[80, 200]"
                layoutDirection="horiz"
                itemSpacings="[8]">
                <TabButton id="searchModeLibrary" label="My Library" hideIcon="true" buttonWidth="260" focusable="true" />
                <TabButton id="searchModeDiscover" label="Discover &amp; Track" hideIcon="true" buttonWidth="320" focusable="true" />
            </LayoutGroup>

            <!-- Filter chips — Library mode only. /api/discover/search
                 doesn't support a type filter so we hide this row in
                 Discover mode (mirrors mobile's conditional render). -->
            <LayoutGroup
                id="searchFilterToggle"
                translation="[80, 300]"
                layoutDirection="horiz"
                itemSpacings="[8]">
                <TabButton id="searchFilterAll" label="All" hideIcon="true" buttonWidth="180" focusable="true" />
                <TabButton id="searchFilterTv" label="TV Shows" hideIcon="true" buttonWidth="220" focusable="true" />
                <TabButton id="searchFilterMovie" label="Movies" hideIcon="true" buttonWidth="200" focusable="true" />
            </LayoutGroup>

            <Label
                id="searchStatus"
                text="Type to search your library."
                translation="[80, 400]"
                color="0xb0b0b0ff" />

            <MarkupGrid
                id="searchResultsGrid"
                itemComponentName="PosterItem"
                translation="[80, 440]"
                itemSize="[220, 400]"
                itemSpacing="[16, 24]"
                numRows="1"
                numColumns="7"
                vertFocusAnimationStyle="floatingFocus"
                focusBitmapBlendColor="0x00000000"
                focusFootprintBlendColor="0x00000000"
                visible="false"
                focusable="true" />
        </Group>

        <!-- ─── Sports view ────────────────────────────────────────
             Mirrors mobile (tabs)/sports.tsx — two horizontal shelves
             ("Sports On Now" + "Sports On Later") rendered with the
             custom SportsCard component. The Home tab still shows the
             same shelves when sports are configured, matching mobile;
             this dedicated tab gives sports its own surface for
             follow-up flows (sports detail, prefs editing).

             itemComponentName (set in HomeScene.brs::init) tells the
             RowList to render each cell with our SportsCard component
             — same plumbing as the Library MarkupGrid using PosterItem. -->
        <Group id="sportsView" visible="false">
            <Label
                id="sportsStatus"
                text="Loading sports…"
                translation="[80, 100]"
                color="0xb0b0b0ff" />

            <!-- itemComponentName (singular, inherited from ArrayGrid)
                 is the right field on RowList — the per-row
                 `rowItemComponentName` variant doesn't exist as a
                 settable field. Set programmatically in init() so we
                 keep the SportsCard wiring with the rest of the row
                 setup. -->
            <RowList
                id="sportsRowList"
                translation="[80, 120]"
                itemSize="[1760, 230]"
                numRows="2"
                rowItemSize="[[340, 160]]"
                rowItemSpacing="[[16, 0]]"
                rowSpacings="[20, 20, 20, 20, 20, 20, 20, 20]"
                vertFocusAnimationStyle="floatingFocus"
                rowFocusAnimationStyle="floatingFocus"
                rowLabelOffset="[[0, 0]]"
                showRowLabel="[true]"
                focusBitmapBlendColor="0x00000000"
                focusFootprintBlendColor="0x00000000"
                visible="false"
                focusable="true" />
        </Group>

        <!-- ─── Settings view ─── -->
        <!-- Mirrors the mobile Settings tab: read-only current state +
             actions. The user picker itself is a separate top-level
             scene (userPickerView) shown at boot AND on Switch User. -->
        <Group id="settingsView" visible="false">
            <Label
                id="settingsTitle"
                text="Settings"
                translation="[80, 100]"
                font="font:LargeBoldSystemFont"
                color="0xffffffff" />

            <!-- settingsContent is the scrollable container. Its
                 translation Y shifts as focus moves between sections
                 to keep the focused row visible. -->
            <Group id="settingsContent" translation="[0, 160]">

                <!-- ─── User ─── -->
                <Label
                    text="User"
                    translation="[80, 0]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <Label
                    id="settingsUserValue"
                    translation="[80, 40]"
                    width="1300"
                    color="0xffffffff" />
                <TabButton
                    id="switchUserButton"
                    label="Switch User"
                    hideIcon="true"
                    buttonWidth="280"
                    translation="[80, 80]"
                    focusable="true" />
                <ToggleRow
                    id="rememberLoginToggle"
                    label="Remember login"
                    translation="[400, 90]"
                    rowWidth="600"
                    focusable="true" />

                <!-- ─── Backend API ─── -->
                <Label
                    text="Backend API"
                    translation="[80, 200]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <Label
                    id="settingsApiUrlValue"
                    translation="[80, 240]"
                    width="1300"
                    color="0xffffffff" />
                <TabButton
                    id="editApiUrlButton"
                    label="Edit URL"
                    hideIcon="true"
                    buttonWidth="240"
                    translation="[80, 280]"
                    focusable="true" />

                <!-- ─── Connection ─── -->
                <Label
                    text="Connection"
                    translation="[80, 400]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <Label
                    id="settingsConnectionValue"
                    translation="[80, 440]"
                    width="800"
                    color="0xffffffff" />
                <LayoutGroup
                    id="connectionToggle"
                    translation="[80, 480]"
                    layoutDirection="horiz"
                    itemSpacings="[8]">
                    <TabButton id="connectionLocal" label="Local (LAN)" hideIcon="true" buttonWidth="240" focusable="true" />
                    <TabButton id="connectionRemote" label="Remote (plex.tv)" hideIcon="true" buttonWidth="320" focusable="true" />
                </LayoutGroup>

                <!-- ─── Playback ─── -->
                <Label
                    text="Playback"
                    translation="[80, 600]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <ToggleRow
                    id="autoSkipIntroToggle"
                    label="Auto-skip intros"
                    translation="[80, 640]"
                    rowWidth="800"
                    focusable="true" />
                <ToggleRow
                    id="autoSkipCreditsToggle"
                    label="Auto-skip credits"
                    translation="[80, 710]"
                    rowWidth="800"
                    focusable="true" />
                <ToggleRow
                    id="showBywToggle"
                    label="&quot;Because you watched&quot; recommendations"
                    translation="[80, 780]"
                    rowWidth="800"
                    focusable="true" />

                <!-- ─── What's on TV ─── -->
                <Label
                    text="What's on TV"
                    translation="[80, 880]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <Label
                    id="settingsLiveTvValue"
                    text="No channels selected"
                    translation="[80, 920]"
                    width="800"
                    color="0xffffffff" />
                <TabButton
                    id="configureChannelsButton"
                    label="Configure Channels"
                    hideIcon="true"
                    buttonWidth="340"
                    translation="[80, 960]"
                    focusable="true" />

                <!-- ─── Sports ─── -->
                <Label
                    text="Sports"
                    translation="[80, 1080]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <Label
                    text="Pick leagues so the Sports tab shows what's on now and what's coming up."
                    translation="[80, 1120]"
                    width="1500"
                    wrap="true"
                    color="0xb0b0b0ff" />
                <TabButton
                    id="configureSportsButton"
                    label="Configure Sports Follows"
                    hideIcon="true"
                    buttonWidth="380"
                    translation="[80, 1160]"
                    focusable="true" />

                <!-- ─── Service Status ─── -->
                <Label
                    text="Service Status"
                    translation="[80, 1280]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <Rectangle id="serviceStatusPlexDot" translation="[80, 1330]" width="14" height="14" color="0x666666ff" />
                <Label id="serviceStatusPlex" translation="[110, 1322]" width="800" color="0xffffffff" text="Plex" />
                <Rectangle id="serviceStatusJellyfinDot" translation="[80, 1366]" width="14" height="14" color="0x666666ff" />
                <Label id="serviceStatusJellyfin" translation="[110, 1358]" width="800" color="0xffffffff" text="Jellyfin" />
                <Rectangle id="serviceStatusEmbyDot" translation="[80, 1402]" width="14" height="14" color="0x666666ff" />
                <Label id="serviceStatusEmby" translation="[110, 1394]" width="800" color="0xffffffff" text="Emby" />
                <Rectangle id="serviceStatusSonarrDot" translation="[80, 1438]" width="14" height="14" color="0x666666ff" />
                <Label id="serviceStatusSonarr" translation="[110, 1430]" width="800" color="0xffffffff" text="Sonarr" />
                <Rectangle id="serviceStatusRadarrDot" translation="[80, 1474]" width="14" height="14" color="0x666666ff" />
                <Label id="serviceStatusRadarr" translation="[110, 1466]" width="800" color="0xffffffff" text="Radarr" />

                <!-- ─── Server Configuration ─── -->
                <Label
                    text="Server Configuration"
                    translation="[80, 1540]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <Label id="serverConfigPlex" translation="[80, 1580]" width="1500" color="0xb0b0b0ff" text="Plex: —" />
                <Label id="serverConfigJellyfin" translation="[80, 1610]" width="1500" color="0xb0b0b0ff" text="Jellyfin: —" />
                <Label id="serverConfigEmby" translation="[80, 1640]" width="1500" color="0xb0b0b0ff" text="Emby: —" />
                <Label id="serverConfigSonarr" translation="[80, 1670]" width="1500" color="0xb0b0b0ff" text="Sonarr: —" />
                <Label id="serverConfigRadarr" translation="[80, 1700]" width="1500" color="0xb0b0b0ff" text="Radarr: —" />

                <!-- ─── Server Updates ───
                     Mirrors the mobile Settings → Server Updates section.
                     Shows current vs. latest backend version, last-check
                     time, and surfaces Check / Install actions. Hidden
                     when the backend reports platformSupported=false. -->
                <Label
                    id="settingsUpdateHeader"
                    text="Server Updates"
                    translation="[80, 1760]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <Label id="settingsUpdateCurrentLabel" text="Current" translation="[80, 1800]" width="280" color="0xb0b0b0ff" />
                <Label id="settingsUpdateCurrentValue" translation="[380, 1800]" width="800" color="0xffffffff" />
                <Label id="settingsUpdateLatestLabel" text="Latest" translation="[80, 1840]" width="280" color="0xb0b0b0ff" />
                <Label id="settingsUpdateLatestValue" translation="[380, 1840]" width="800" color="0xffffffff" />
                <Label id="settingsUpdateCheckedLabel" text="Last checked" translation="[80, 1880]" width="280" color="0xb0b0b0ff" />
                <Label id="settingsUpdateCheckedValue" translation="[380, 1880]" width="800" color="0xffffffff" />
                <Label id="settingsUpdateMessage" translation="[80, 1920]" width="1700" wrap="true" color="0xff8080ff" />
                <TabButton id="checkUpdateButton" label="Check for Updates" hideIcon="true" buttonWidth="320" translation="[80, 1960]" focusable="true" />
                <TabButton id="installUpdateButton" label="Install Update" hideIcon="true" buttonWidth="280" translation="[420, 1960]" visible="false" focusable="true" />

                <!-- ─── Pair Device ─── -->
                <Label
                    text="Pair Device"
                    translation="[80, 2080]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <Label
                    text="Re-pair this Roku if you reset the backend's admin password or moved to a new server."
                    translation="[80, 2120]"
                    width="1500"
                    wrap="true"
                    color="0xb0b0b0ff" />
                <TabButton
                    id="repairButton"
                    label="Pair this device again"
                    hideIcon="true"
                    buttonWidth="380"
                    translation="[80, 2160]"
                    focusable="true" />

                <!-- ─── About ─── -->
                <Label
                    text="About"
                    translation="[80, 2280]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <Label id="aboutVersionLabel" translation="[80, 2320]" width="1500" color="0xb0b0b0ff" text="Version —" />
            </Group>
        </Group>

        <!-- ─── Sports settings sub-view ──────────────────────────────
             Reached from Settings → Configure Sports Follows. Shows a
             checkbox list of supported leagues; toggling sets that
             league's mode to "all" (or removes it from prefs). Per-team
             selection is a follow-up — for now Roku covers the league
             toggle path mobile users hit most. -->
        <Group id="sportsSettingsView" visible="false">
            <Label
                text="Sports Follows"
                translation="[80, 110]"
                font="font:LargeBoldSystemFont"
                color="0xe5a00dff" />
            <Label
                text="Toggle the leagues you follow. The Sports tab shows games for selected leagues."
                translation="[80, 190]"
                width="1700"
                wrap="true"
                color="0xb0b0b0ff" />
            <Label
                id="sportsSettingsStatus"
                text="Loading leagues…"
                translation="[80, 280]"
                color="0xb0b0b0ff" />
            <LabelList
                id="sportsLeagueList"
                translation="[80, 280]"
                itemSize="[800, 60]"
                numRows="11"
                vertFocusAnimationStyle="floatingFocus"
                visible="false"
                focusable="true" />
            <Label
                text="OK toggles a league. Press Back to return — changes save automatically."
                translation="[80, 970]"
                width="1700"
                color="0x707070ff" />
        </Group>

        <!-- ─── User picker view ─────────────────────────────────────
             Shown at startup when no Plex user is saved, and on
             Settings → Switch User. Mirrors the mobile select-user
             screen: title + scrollable list of Plex Home users. -->
        <Group id="userPickerView" visible="false">
            <Label
                id="userPickerTitle"
                text="Who's Watching?"
                translation="[80, 200]"
                font="font:LargeBoldSystemFont"
                color="0xe5a00dff" />

            <Label
                id="userPickerSubtitle"
                text="Choose a Plex Home user."
                translation="[80, 280]"
                color="0xb0b0b0ff" />

            <Label
                id="userPickerStatus"
                text="Loading users…"
                translation="[80, 360]"
                color="0xb0b0b0ff" />

            <LabelList
                id="userList"
                translation="[80, 360]"
                itemSize="[600, 70]"
                numRows="8"
                vertFocusAnimationStyle="floatingFocus"
                visible="false"
                focusable="true" />
        </Group>

        <!-- ─── Pair view: shown on first run when the backend has an
             admin password and this device hasn't been paired yet.
             User reads the 6-digit code, types it in /setup → Devices,
             we poll /api/auth/pair/poll until the admin completes it,
             then save the auth key to the registry. -->
        <Group id="pairView" visible="false">
            <Label
                id="pairTitle"
                text="Pair this device"
                translation="[80, 200]"
                font="font:LargeBoldSystemFont"
                color="0xe5a00dff" />

            <Label
                id="pairSubtitle"
                translation="[80, 290]"
                width="1700"
                wrap="true"
                font="font:MediumBoldSystemFont"
                color="0xc0c0c0ff" />

            <!-- Big monospaced-ish code. font size pushed via SystemFontFile
                 so it dominates the screen — admin reads it off the TV
                 and types it into /setup. -->
            <Label
                id="pairCode"
                translation="[80, 400]"
                width="1700"
                font="font:LargeBoldSystemFont"
                color="0xffffffff" />

            <Label
                id="pairStatus"
                translation="[80, 560]"
                width="1700"
                wrap="true"
                color="0xb0b0b0ff" />

            <Label
                id="pairHint"
                text="Press OK to refresh the code. Press * to change the server URL."
                translation="[80, 640]"
                width="1700"
                color="0x707070ff" />
        </Group>

        <!-- ─── Live TV channel picker ───────────────────────────────
             Reached from Settings → Configure Channels. Loads the
             available TVmaze channels from /api/live/channels, lets
             the user toggle each one. Changes save immediately and
             mark the home shelves stale; on Back we return to the
             Settings view and the next visit to Home refetches. -->
        <Group id="liveTvView" visible="false">
            <Label
                text="What's on TV"
                translation="[80, 110]"
                font="font:LargeBoldSystemFont"
                color="0xe5a00dff" />

            <Label
                text="Pick the channels you watch. Home will show what's on now and what's coming up on these channels."
                translation="[80, 190]"
                width="1700"
                wrap="true"
                color="0xb0b0b0ff" />

            <Label
                id="liveTvViewStatus"
                text="Loading channels…"
                translation="[80, 280]"
                color="0xb0b0b0ff" />

            <LabelList
                id="channelList"
                translation="[80, 280]"
                itemSize="[800, 60]"
                numRows="11"
                vertFocusAnimationStyle="floatingFocus"
                visible="false"
                focusable="true" />

            <Label
                text="OK toggles a channel. Press Back when done — your selection is saved automatically."
                translation="[80, 970]"
                width="1700"
                color="0x707070ff" />
        </Group>

        <!-- ─── Detail view: hero + metadata + actions ─── -->
        <Group id="detailView" visible="false">
            <!-- scaleToZoom centre-crops backdrops that aren't 16:9
                 instead of stretching them across the full screen. -->
            <Poster
                id="detailBackdrop"
                width="1920"
                height="1080"
                opacity="0.4"
                loadDisplayMode="scaleToZoom" />

            <Rectangle width="1920" height="1080" color="0x000000aa" />

            <Label
                id="detailTitle"
                translation="[120, 200]"
                width="1300"
                font="font:LargeBoldSystemFont"
                color="0xffffffff" />

            <Label
                id="detailSubtitle"
                translation="[120, 280]"
                width="1300"
                font="font:MediumBoldSystemFont"
                color="0xc0c0c0ff" />

            <Label
                id="detailMeta"
                translation="[120, 340]"
                width="1300"
                color="0xa0a0a0ff" />

            <Label
                id="detailSummary"
                translation="[120, 400]"
                width="1300"
                wrap="true"
                maxLines="6"
                color="0xe0e0e0ff" />

            <!-- ButtonGroup auto-handles D-pad navigation between Buttons.
                 All buttons are present in XML; populateDetail in
                 HomeScene.brs toggles their visibility per item type:
                   - library items (plex/jellyfin/emby): Play, Mark*, Back
                   - tracked TV: Add to Sonarr, Back
                   - tracked Movie: Add to Radarr, Back
                   - sports / sonarr / radarr: Back
                 ButtonGroup skips invisible buttons in its focus chain
                 so the user only steps through what's relevant. -->
            <!-- App-styled ActionButton + LayoutGroup replaces Roku's
                 built-in ButtonGroup + Button so the action row matches
                 the rest of the channel's gold-on-dark theme. Each
                 ActionButton fires its own `actionSelected` field; the
                 handler observers live in init() rather than the
                 single buttonSelected switch ButtonGroup used to drive.
                 Left/Right traversal is wired manually in onKeyEvent. -->
            <LayoutGroup
                id="detailActions"
                translation="[120, 720]"
                layoutDirection="horiz"
                itemSpacings="[24]">
                <ActionButton id="playButton" text="Play" buttonWidth="240" focusable="true" />
                <ActionButton id="goToShowButton" text="Go to Show" buttonWidth="240" focusable="true" />
                <ActionButton id="markWatchedButton" text="Mark as Watched" buttonWidth="320" focusable="true" />
                <ActionButton id="markUnwatchedButton" text="Mark as Unwatched" buttonWidth="340" focusable="true" />
                <ActionButton id="trackButton" text="Track" buttonWidth="200" focusable="true" />
                <ActionButton id="addSonarrButton" text="Add to Sonarr" buttonWidth="280" focusable="true" />
                <ActionButton id="addRadarrButton" text="Add to Radarr" buttonWidth="280" focusable="true" />
                <ActionButton id="backButton" text="Back" buttonWidth="240" focusable="true" />
            </LayoutGroup>

            <!-- Inline status row for Add → "Adding…" / "Added to Sonarr" /
                 error messages. Sits just below the action row. -->
            <Label
                id="detailAddStatus"
                translation="[120, 800]"
                width="1300"
                color="0xe5a00dff"
                visible="false" />
        </Group>

        <!-- ─── Show detail view: seasons + episodes browser ─── -->
        <!-- Reached via the Go to Show button on the regular detail view
             when an episode is selected. Mirrors mobile's show-detail.tsx
             layout: backdrop at top, show poster + title + summary on
             the left, action buttons below; seasons LabelList + episodes
             MarkupGrid in the lower section. -->
        <Group id="showDetailView" visible="false">
            <!-- scaleToZoom = aspect-preserving crop (CSS object-fit:
                 cover). scaleToFill stretches the image to the exact
                 box dims, which looked smushed on backdrops whose
                 native ratio isn't 1920×540 (≈ 3.56:1) — most backdrops
                 are 16:9 (≈ 1.78:1) so they were horizontally
                 stretched. -->
            <Poster
                id="showDetailBackdrop"
                width="1920"
                height="540"
                loadDisplayMode="scaleToZoom" />
            <Rectangle width="1920" height="540" color="0x000000b0" />

            <Poster
                id="showDetailPoster"
                translation="[80, 110]"
                width="240"
                height="360"
                loadDisplayMode="scaleToFit" />

            <Label
                id="showDetailTitle"
                translation="[340, 120]"
                width="1500"
                wrap="false"
                maxLines="1"
                font="font:LargeBoldSystemFont"
                color="0xffffffff" />
            <Label
                id="showDetailMeta"
                translation="[340, 180]"
                width="1500"
                color="0xb0b0b0ff" />
            <Label
                id="showDetailSummary"
                translation="[340, 230]"
                width="1500"
                height="160"
                wrap="true"
                maxLines="4"
                color="0xdcdcdcff" />

            <LayoutGroup
                id="showDetailActions"
                translation="[340, 410]"
                layoutDirection="horiz"
                itemSpacings="[24]">
                <ActionButton id="showDetailMarkAllWatched" text="Mark All Watched" buttonWidth="320" focusable="true" />
                <ActionButton id="showDetailMarkAllUnwatched" text="Mark All Unwatched" buttonWidth="340" focusable="true" />
                <ActionButton id="showDetailBackButton" text="Back" buttonWidth="200" focusable="true" />
            </LayoutGroup>

            <Label
                translation="[80, 530]"
                width="240"
                font="font:MediumBoldSystemFont"
                color="0xe5a00dff"
                text="Seasons" />
            <LabelList
                id="showDetailSeasonsList"
                translation="[80, 580]"
                itemSize="[260, 60]"
                numRows="7"
                vertFocusAnimationStyle="floatingFocus"
                focusable="true" />

            <Label
                translation="[400, 530]"
                width="800"
                font="font:MediumBoldSystemFont"
                color="0xe5a00dff"
                text="Episodes" />
            <Label
                id="showDetailEpisodesStatus"
                translation="[400, 580]"
                width="1400"
                color="0xb0b0b0ff"
                text="" />
            <!-- Vertical episode list: landscape thumb + title + summary
                 per row, mirrors mobile/web. Single-column MarkupGrid
                 with 3 visible rows; user scrolls down through episodes
                 rather than panning sideways. -->
            <MarkupGrid
                id="showDetailEpisodesGrid"
                itemComponentName="EpisodeListItem"
                translation="[400, 580]"
                itemSize="[1380, 152]"
                itemSpacing="[0, 14]"
                numRows="3"
                numColumns="1"
                vertFocusAnimationStyle="floatingFocus"
                focusable="true" />
        </Group>

        <!-- ─── Player view: fullscreen Video ─── -->
        <!-- enableUI=true gives us Roku's built-in transport overlay:
             auto-shows when playback starts, auto-hides after a few
             seconds of inactivity, re-shows on OK / Up / Down.
             Focus targets the Video node directly so those keypresses
             reach it. Back: first press dismisses the overlay, second
             press bubbles up to Scene.onKeyEvent which returns to
             detail (existing handler). -->
        <Group id="playerView" visible="false">
            <!-- Roku's enableUI=true provides the standard transport UI
                 (scrub, time codes, title overlay). We layered a custom
                 bar on top earlier and the two collided visually, so the
                 channel now relies on Roku's built-in. Quality / subtitle
                 / audio pickers are channel-side overlays since Roku's
                 transport doesn't surface those. -->
            <Video id="video" width="1920" height="1080" enableUI="true" />

            <!-- Tracks picker overlay — opened by Down key during
                 playback. Multi-select: user can change audio AND
                 subtitle without dismissing, then presses Close to
                 apply both as a single re-issue. Sits on top of the
                 still-visible playerView (just toggles visible). -->
            <!-- Combined playback-settings picker — opened by Up during
                 playback. Three tabs (Quality / Audio / Subtitles)
                 switched by Left/Right. OK on a list item commits +
                 closes; Back cancels. Down during playback is reserved
                 for Roku's native transport overlay. -->
            <Group id="tracksView" visible="false">
                <Rectangle width="1920" height="1080" color="0x000000bb" />
                <!-- Content panel — lighter, covers full panel area. -->
                <Rectangle translation="[460, 140]" width="1000" height="800" color="0x202020ff" />
                <!-- Header strip — slightly darker than the content
                     area below; visually groups title + tab labels +
                     the keyboard-hint line. Drawn after the content
                     panel and before the labels so it sits between
                     them in the z-order. -->
                <Rectangle translation="[460, 140]" width="1000" height="180" color="0x161616ff" />

                <Label
                    text="Playback Settings"
                    translation="[500, 160]"
                    font="font:LargeBoldSystemFont"
                    color="0xe5a00dff" />

                <Label
                    id="tracksTabQualityLabel"
                    text="Quality"
                    translation="[500, 230]"
                    font="font:MediumBoldSystemFont"
                    color="0xe5a00dff" />
                <Label
                    id="tracksTabAudioLabel"
                    text="Audio"
                    translation="[760, 230]"
                    font="font:MediumBoldSystemFont"
                    color="0x808080ff" />
                <Label
                    id="tracksTabSubtitleLabel"
                    text="Subtitles"
                    translation="[990, 230]"
                    font="font:MediumBoldSystemFont"
                    color="0x808080ff" />

                <!-- Hint line. Arrow glyphs are pulled from Noto Sans
                     Symbols 2 (same font the top-bar tabs use), so
                     they render correctly. Text labels use the system
                     font, so we split into multiple Labels inside a
                     horizontal LayoutGroup. translation x picked to
                     visually centre the ~520px content row within the
                     1000px panel (panel left x=460, panel centre
                     x=960; 960 - 520/2 ≈ 700). -->
                <LayoutGroup
                    translation="[610, 292]"
                    layoutDirection="horiz"
                    itemSpacings="[8]"
                    vertAlignment="center">
                    <Label text="◀ ▶" color="0x606060ff">
                        <Font role="font" uri="pkg:/fonts/NotoSansSymbols2.ttf" size="20" />
                    </Label>
                    <Label text="switch  ·" color="0x606060ff" font="font:SmallSystemFont" />
                    <Label text="▲ ▼" color="0x606060ff">
                        <Font role="font" uri="pkg:/fonts/NotoSansSymbols2.ttf" size="20" />
                    </Label>
                    <Label text="navigate  ·  OK select  ·  Back cancel" color="0x606060ff" font="font:SmallSystemFont" />
                </LayoutGroup>

                <!-- Three lists stacked at the same position; only one
                     is visible at a time. setActiveTab() flips
                     visibility + focus. -->
                <LabelList
                    id="tracksQualityList"
                    translation="[500, 330]"
                    itemSize="[920, 50]"
                    numRows="11"
                    vertFocusAnimationStyle="floatingFocus"
                    focusable="true" />
                <LabelList
                    id="tracksAudioList"
                    translation="[500, 330]"
                    itemSize="[920, 50]"
                    numRows="11"
                    vertFocusAnimationStyle="floatingFocus"
                    focusable="true"
                    visible="false" />
                <LabelList
                    id="tracksSubtitleList"
                    translation="[500, 330]"
                    itemSize="[920, 50]"
                    numRows="11"
                    vertFocusAnimationStyle="floatingFocus"
                    focusable="true"
                    visible="false" />
            </Group>

            <!-- Skip Intro / Skip Credits button. Auto-shows when the
                 current Video.position is inside a Plex marker range
                 and gets focus so OK fires it. Back dismisses for the
                 remainder of that marker (so users can watch the intro
                 if they want without the button popping back up). -->
            <ActionButton
                id="skipButton"
                text="Skip Intro"
                translation="[1500, 820]"
                buttonWidth="320"
                visible="false"
                focusable="true" />
        </Group>
    </children>
</component>
