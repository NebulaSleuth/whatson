<?xml version="1.0" encoding="utf-8" ?>
<!--
  Cell renderer for the Library MarkupGrid + the Home/TV/Movies/Search
  result lists (set via itemComponentName).

  Layout — driven by the rules:
    * Poster aspect MUST be exactly 2:3. We size the poster 160×240
      (the same dimensions mobile uses for TV cards) and let it fill
      the cell. RowList/MarkupGrid's rowItemSize is [160, 240] so the
      cell IS the poster — Roku's built-in `floatingFocus` then snaps
      to the poster bounds, "starts below the title, ends at cell
      bottom".
    * The cell label sits BELOW the cell (translation y=246) so it
      doesn't eat into the 2:3 poster area. The row's itemSize
      includes enough vertical room for the label without spilling
      into the next shelf.
    * Source badge has a slightly bigger font (16px) and the text is
      centered horizontally inside the rect.
    * Top "padding" between the shelf title and the poster comes from
      Roku's natural row layout — no extra padding added inside the
      cell, which would push the poster out of 2:3.

  Reads:
    - HDPosterUrl   standard ContentNode field
    - title         standard ContentNode field
    - itemSource    custom string ("plex" | "jellyfin" | "emby" | ...)
    - itemProgress  custom float, 0..100 — drives the progress strip
    - itemWatched   custom boolean — when true, dims the poster
-->
<component name="PosterItem" extends="Group">
    <script type="text/brightscript" uri="PosterItem.brs" />

    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
        <!-- RowList sets `focusPercent` per row (i.e. the last-focused
             cell in each row stays at 1.0 even when the row isn't the
             active row). `rowFocusPercent` IS the row-level focus, so
             combining the two gives us "this cell is THE focused cell
             across the whole list". Without this, focus rings linger
             on every row the user previously visited. -->
        <field id="rowFocusPercent" type="float" onChange="onFocusChanged" />
    </interface>

    <children>
        <!-- Translated wrapper — pushes everything down 16px inside the
             cell so the RowList's row title has visible breathing room
             above the poster. Cell content overflows the rowItemSize
             bounds (which is fine — Roku doesn't clip), and the row's
             itemSize includes enough vertical room. -->
        <Group id="cellInner" translation="[0, 12]">
        <!-- Poster fills the 220×330 cell — exact 2:3. -->
        <!-- scaleToZoom = aspect-fill from centre. Source images that
             aren't the typical 2:3 ratio (square promo art, ultrawide
             stills) get cropped to fill the cell instead of squeezed. -->
        <Poster
            id="poster"
            width="220"
            height="330"
            loadDisplayMode="scaleToZoom" />

        <!-- Corner-radius hack — Roku Poster nodes don't support
             border-radius natively, so we overlay 4 small bg-coloured
             squares to "cut" the corners. Colour matches the scene
             background (0x0e0e0eff) so the corners blend with whatever
             surface the poster sits on. Gives a clipped-corner look
             close enough to the rounded posters on mobile + web; a
             true rounded-mask PNG would be the only way to get real
             antialiased curves.
             Cell is 220×330 — corner squares 10×10 at each corner. -->
        <Rectangle id="cornerTL" width="10" height="10" color="0x0e0e0eff" />
        <Rectangle id="cornerTR" translation="[210, 0]" width="10" height="10" color="0x0e0e0eff" />
        <Rectangle id="cornerBL" translation="[0, 320]" width="10" height="10" color="0x0e0e0eff" />
        <Rectangle id="cornerBR" translation="[210, 320]" width="10" height="10" color="0x0e0e0eff" />

        <!-- Watched dim overlay — covers the poster but sits below the
             badges so source/progress remain legible on watched items. -->
        <Rectangle
            id="watchedDim"
            width="220"
            height="330"
            color="0x00000088"
            visible="false" />

        <!-- Source badge (top-left). 16px text, centered both ways.
             Label translation matches the rect so vertAlign="center"
             lines the text up against the rect's vertical centre. -->
        <Rectangle
            id="sourceBadgeBg"
            translation="[6, 6]"
            width="68"
            height="20"
            color="0xe5a00dff"
            visible="false" />
        <Label
            id="sourceBadgeLabel"
            translation="[6, 6]"
            width="68"
            height="20"
            horizAlign="center"
            vertAlign="center"
            wrap="false"
            maxLines="1"
            color="0x000000ff"
            visible="false">
            <Font role="font" uri="font:SystemFontFile" size="16" />
        </Label>

        <!-- Status overlay — pinned to the bottom edge of the poster.
             Shows the formatted air date for coming_soon items and
             live-source items, or a "Downloading" badge for in-flight
             Sonarr/Radarr jobs. Mirrors the mobile ContentCard
             statusOverlay. -->
        <Rectangle
            id="statusOverlayBg"
            translation="[0, 296]"
            width="220"
            height="28"
            color="0x000000bf"
            visible="false" />
        <Label
            id="statusOverlayLabel"
            translation="[0, 296]"
            width="220"
            height="28"
            horizAlign="center"
            vertAlign="center"
            wrap="false"
            maxLines="1"
            color="0xe5a00dff"
            visible="false">
            <Font role="font" uri="font:SystemFontFile" size="16" />
        </Label>

        <!-- Progress bar — pinned to the bottom edge of the poster. -->
        <Rectangle
            id="progressBarBg"
            translation="[0, 324]"
            width="220"
            height="6"
            color="0x000000aa"
            visible="false" />
        <Rectangle
            id="progressBarFill"
            translation="[0, 324]"
            width="0"
            height="6"
            color="0xe5a00dff"
            visible="false" />

        <!-- Title label sits below the cell (y > 330). RowList's
             itemSize must be tall enough to include this — see
             HomeScene.xml. 20px to keep the title readable now that
             the posters are 220×330. -->
        <Label
            id="label"
            translation="[0, 336]"
            width="220"
            horizAlign="center"
            wrap="false"
            maxLines="1"
            color="0xb0b0b0ff">
            <Font role="font" uri="font:SystemFontFile" size="20" />
        </Label>

        <!-- Sports-mode card — landscape variant matching SportsCard's
             340×160 layout used on the Sports tab. Hidden by default;
             toggled on when itemContent.itemSource = "sports". Home's
             rowList sets rowItemSize per-row so sports shelves get
             340×160 cells while library / live shelves stay 160×240.
             Reads the same flat fields buildSportsCardChild stamps on
             each ContentNode (league, team1Name, team1LogoUrl,
             statusText, bgColor, …) so home + Sports-tab cards share
             data plumbing. -->
        <Group id="sportsView" visible="false">
            <Rectangle id="sportsBg" width="340" height="160" color="0x1a1a1aff" />
            <Rectangle id="sportsAccent" width="340" height="6" color="0xe5a00dff" visible="false" />

            <!-- Header: league + LIVE pill. Explicit font sizes sit
                 between the previous tight 14/16 and Roku's default ~24:
                 league 18, team names 20, scores 20, status 16, pills 14.
                 Geometry follows SportsCard.xml's 340×160 layout. -->
            <Label
                id="sportsLeague"
                translation="[12, 12]"
                width="240"
                wrap="false"
                maxLines="1"
                color="0xb0b0b0ff">
                <Font role="font" uri="font:SystemFontFile" size="22" />
            </Label>

            <Group id="sportsLiveBadge" translation="[278, 10]" visible="false">
                <Rectangle width="50" height="20" color="0xe53935ff" />
                <Rectangle translation="[5, 7]" width="6" height="6" color="0xffffffff" />
                <Label
                    translation="[14, 1]"
                    text="LIVE"
                    width="36"
                    height="20"
                    wrap="false"
                    vertAlign="center"
                    color="0xffffffff">
                    <Font role="font" uri="font:SystemFontFile" size="16" />
                </Label>
            </Group>

            <!-- Team 1 row -->
            <Poster
                id="sportsT1Logo"
                translation="[12, 46]"
                width="26"
                height="26"
                loadDisplayMode="scaleToFit" />
            <Label
                id="sportsT1Name"
                translation="[44, 46]"
                width="200"
                wrap="false"
                maxLines="1"
                color="0xffffffff">
                <Font role="font" uri="font:SystemFontFile" size="22" />
            </Label>
            <Label
                id="sportsT1Score"
                translation="[252, 46]"
                width="74"
                horizAlign="right"
                wrap="false"
                color="0xffffffff"
                visible="false">
                <Font role="font" uri="font:SystemFontFile" size="22" />
            </Label>

            <!-- Team 2 row -->
            <Poster
                id="sportsT2Logo"
                translation="[12, 78]"
                width="26"
                height="26"
                loadDisplayMode="scaleToFit" />
            <Label
                id="sportsT2Name"
                translation="[44, 78]"
                width="200"
                wrap="false"
                maxLines="1"
                color="0xffffffff">
                <Font role="font" uri="font:SystemFontFile" size="22" />
            </Label>
            <Label
                id="sportsT2Score"
                translation="[252, 78]"
                width="74"
                horizAlign="right"
                wrap="false"
                color="0xffffffff"
                visible="false">
                <Font role="font" uri="font:SystemFontFile" size="22" />
            </Label>

            <!-- vs separator hidden in landscape (teams stack with logos). -->
            <Label
                id="sportsVs"
                translation="[42, 56]"
                width="0"
                visible="false"
                color="0x808080ff" />

            <!-- Tournament title (non-team sports like ATP) -->
            <Label
                id="sportsTournament"
                translation="[12, 56]"
                width="316"
                wrap="true"
                maxLines="2"
                color="0xffffffff"
                visible="false">
                <Font role="font" uri="font:SystemFontFile" size="22" />
            </Label>

            <!-- Footer scrim + status + broadcast pill -->
            <Rectangle
                id="sportsScrim"
                translation="[0, 122]"
                width="340"
                height="38"
                color="0x00000058"
                visible="false" />
            <Label
                id="sportsStatus"
                translation="[12, 130]"
                width="200"
                wrap="false"
                maxLines="1"
                color="0xc0c0c0ff">
                <Font role="font" uri="font:SystemFontFile" size="18" />
            </Label>

            <Group id="sportsBroadcastPill" translation="[240, 128]" visible="false">
                <Rectangle id="sportsBroadcastBg" width="88" height="22" color="0xe5a00d33" />
                <Label
                    id="sportsBroadcastLabel"
                    translation="[6, 1]"
                    width="76"
                    height="22"
                    wrap="false"
                    horizAlign="center"
                    vertAlign="center"
                    color="0xe5a00dff">
                    <Font role="font" uri="font:SystemFontFile" size="16" />
                </Label>
            </Group>
        </Group>

        <!-- Inset 4-strip focus ring drawn LAST so the strips overlay
             the outer ~4px of the poster (or sports card). Sits inside
             cellInner — RowList clips at x=0 of the row, so we can't
             extend a ring outside the cell. Strips are sized + moved
             at runtime via PosterItem.brs when the cell switches
             between portrait (220×330) and sports (340×160). -->
        <Rectangle id="focusRingTop"    translation="[0, 0]"    width="220" height="4"   color="0x00000000" />
        <Rectangle id="focusRingBottom" translation="[0, 326]"  width="220" height="4"   color="0x00000000" />
        <Rectangle id="focusRingLeft"   translation="[0, 4]"    width="4"   height="322" color="0x00000000" />
        <Rectangle id="focusRingRight"  translation="[216, 4]"  width="4"   height="322" color="0x00000000" />
        </Group>
    </children>
</component>
