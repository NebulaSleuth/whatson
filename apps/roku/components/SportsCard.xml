<?xml version="1.0" encoding="utf-8" ?>
<!--
  SportsCard — per-cell renderer for the Sports tab's RowList. Mirrors
  the mobile components/SportsShelf.tsx SportsCard at 340×160 (tvOS /
  Android TV size).

  Visual model:
    - background Rectangle (team color for upcoming, surface dark for live)
    - 6px team-color accent strip across the top for live games
    - league label (top-left), LIVE pill (top-right)
    - two team rows: logo + name + score (live only)
    - footer: status text (formatted time for upcoming) + broadcast pill
    - dark scrim across the bottom on coloured upcoming cards so the
      footer text stays legible over bright primary colours
    - 4px gold focus ring that peeks out from behind the card when focused

  Field plumbing: HomeScene.brs builds the per-card ContentNode with a
  flat set of strings (team1Name, team1LogoUrl, etc.). Layered colour
  decisions (luminance, accent picks) happen there too — this component
  just paints what it's told.
-->
<component name="SportsCard" extends="Group">
    <script type="text/brightscript" uri="SportsCard.brs" />

    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
        <!-- Row-level focus: paired with focusPercent so only the
             actively-focused cell in the actively-focused row paints
             the ring (RowList keeps each row's last-focused cell at
             focusPercent=1.0 otherwise, leaving stale rings behind). -->
        <field id="rowFocusPercent" type="float" onChange="onFocusChanged" />
    </interface>

    <children>
        <!-- Card background. Color is overwritten in onContentChanged
             based on whether the event is live (surface) or upcoming
             (team primary colour, with a fallback to surface). -->
        <Rectangle
            id="bg"
            width="340"
            height="160"
            color="0x1a1a1aff" />

        <!-- Live accent bar across the top, hidden for upcoming. -->
        <Rectangle
            id="accentBar"
            width="340"
            height="6"
            color="0xe5a00dff"
            visible="false" />

        <!-- Dark scrim behind the footer for upcoming-card legibility. -->
        <Rectangle
            id="scrim"
            translation="[0, 120]"
            width="340"
            height="40"
            color="0x00000058"
            visible="false" />

        <!-- Header: league + LIVE pill. Explicit font sizes match
             PosterItem.xml's sportsView on the Home tab so cards look
             identical on both surfaces: league 18, team names + scores
             20, status 16, LIVE / broadcast pills 14. -->
        <Label
            id="leagueLabel"
            translation="[12, 12]"
            width="240"
            wrap="false"
            maxLines="1"
            color="0xb0b0b0ff">
            <Font role="font" uri="font:SystemFontFile" size="20" />
        </Label>

        <Group id="liveBadge" translation="[278, 10]" visible="false">
            <Rectangle width="50" height="20" color="0xe53935ff" />
            <Rectangle translation="[5, 7]" width="6" height="6" color="0xffffffff" />
            <Label
                translation="[14, 1]"
                text="LIVE"
                width="36"
                height="20"
                wrap="false"
                vertAlign="center"
                color="0xffffffff">
                <Font role="font" uri="font:SystemFontFile" size="16" />
            </Label>
        </Group>

        <!-- Team 1 row -->
        <Poster
            id="team1Logo"
            translation="[12, 46]"
            width="26"
            height="26"
            loadDisplayMode="scaleToFit" />
        <Label
            id="team1Name"
            translation="[44, 46]"
            width="200"
            wrap="false"
            maxLines="1"
            color="0xffffffff">
            <Font role="font" uri="font:SystemFontFile" size="22" />
        </Label>
        <Label
            id="team1Score"
            translation="[252, 46]"
            width="74"
            horizAlign="right"
            wrap="false"
            color="0xffffffff">
            <Font role="font" uri="font:SystemFontFile" size="22" />
        </Label>

        <!-- Team 2 row -->
        <Poster
            id="team2Logo"
            translation="[12, 78]"
            width="26"
            height="26"
            loadDisplayMode="scaleToFit" />
        <Label
            id="team2Name"
            translation="[44, 78]"
            width="200"
            wrap="false"
            maxLines="1"
            color="0xffffffff">
            <Font role="font" uri="font:SystemFontFile" size="22" />
        </Label>
        <Label
            id="team2Score"
            translation="[252, 78]"
            width="74"
            horizAlign="right"
            wrap="false"
            color="0xffffffff">
            <Font role="font" uri="font:SystemFontFile" size="22" />
        </Label>

        <!-- Tournament title (non-team sports like ATP) overlays the
             team rows when shown. Hidden by default; live/upcoming
             team-sport branches hide it explicitly. -->
        <Label
            id="tournamentTitle"
            translation="[12, 56]"
            width="316"
            wrap="true"
            maxLines="2"
            color="0xffffffff"
            visible="false">
            <Font role="font" uri="font:SystemFontFile" size="22" />
        </Label>

        <!-- Footer: status + broadcast pill -->
        <Label
            id="statusLabel"
            translation="[12, 130]"
            width="200"
            wrap="false"
            maxLines="1"
            color="0xc0c0c0ff">
            <Font role="font" uri="font:SystemFontFile" size="18" />
        </Label>

        <Group id="broadcastPill" translation="[240, 128]" visible="false">
            <Rectangle id="broadcastBg" width="88" height="22" color="0xe5a00d33" />
            <Label
                id="broadcastLabel"
                translation="[6, 1]"
                width="76"
                height="22"
                wrap="false"
                horizAlign="center"
                vertAlign="center"
                color="0xe5a00dff">
                <Font role="font" uri="font:SystemFontFile" size="16" />
            </Label>
        </Group>

        <!-- Inset 4-strip focus ring drawn LAST so the strips overlay
             the outer ~4px of the card. RowList clips an outer ring
             at the row's left edge for the first cell, so the strips
             stay inside the cell bounds. -->
        <Rectangle id="focusRingTop"    translation="[0, 0]"   width="340" height="4"   color="0x00000000" />
        <Rectangle id="focusRingBottom" translation="[0, 156]" width="340" height="4"   color="0x00000000" />
        <Rectangle id="focusRingLeft"   translation="[0, 4]"   width="4"   height="152" color="0x00000000" />
        <Rectangle id="focusRingRight"  translation="[336, 4]" width="4"   height="152" color="0x00000000" />
    </children>
</component>
