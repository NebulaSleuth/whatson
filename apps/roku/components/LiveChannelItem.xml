<?xml version="1.0" encoding="utf-8" ?>
<!--
  Cell renderer for the Live TV channel grid. Wide horizontal layout:

    Cell 560 × 240
      ┌─────────────────┬──────────────────────────┐
      │                 │ 5.1  WCBS-DT       [HD]  │
      │   [logo PNG]    │                          │
      │                 │ Now: 60 Minutes          │
      │                 │ Next: NFL Football       │
      └─────────────────┴──────────────────────────┘

  When no logo is available the left side renders the channel number
  + callSign in the same band so the right column doesn't shift.

  Reads via itemContent (ContentNode populated by HomeScene.brs):
    - itemChannelId       source-prefixed id (`hdhr-5.1`)
    - itemChannelNumber   string (`5.1`)
    - itemChannelName     display name (`WCBS-DT`)
    - itemChannelCallSign (often same as name)
    - itemChannelLogoUrl  optional artwork URL (Silicondust guide)
    - itemChannelHd       boolean — show HD chip in top-right
    - itemNowProgram      "60 Minutes" (current program title)
    - itemNextProgram     "NFL Football" (next program title)
-->
<component name="LiveChannelItem" extends="Group">
    <script type="text/brightscript" uri="LiveChannelItem.brs" />

    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
        <field id="rowFocusPercent" type="float" onChange="onFocusChanged" />
    </interface>

    <children>
        <!-- Cell background; darkens when focused. -->
        <Rectangle id="cellBg" width="560" height="240" color="0x1a1a1aff" />

        <!-- Subtle vertical divider between logo and info halves. -->
        <Rectangle translation="[230, 24]" width="1" height="192" color="0x2a2a2aff" />

        <!-- ─── Left half: logo OR fallback channel number ─── -->
        <Poster
            id="logo"
            translation="[16, 24]"
            width="200"
            height="192"
            loadDisplayMode="scaleToFit"
            visible="false" />
        <!-- Fallback when no logo: large channel number + callsign
             stacked in the left half so the right info column stays
             at a fixed x. -->
        <Label
            id="channelNumber"
            translation="[16, 70]"
            width="200"
            horizAlign="center"
            color="0xffffffff"
            font="font:LargeBoldSystemFont" />
        <Label
            id="channelCallSign"
            translation="[16, 140]"
            width="200"
            horizAlign="center"
            color="0xb0b0b0ff"
            font="font:MediumBoldSystemFont" />

        <!-- ─── Right half: channel name + EPG + HD chip ─── -->
        <!-- Top header line — channel number (gold accent) +
             call sign / name. SmallBoldSystemFont keeps both
             readable while leaving room for longer numbers
             like "104.1" or "999.9" that don't fit at the
             larger Medium weight. -->
        <Label
            id="rightChannelNumber"
            translation="[252, 24]"
            width="80"
            height="26"
            vertAlign="center"
            color="0xf5d87aff"
            font="font:SmallBoldSystemFont" />
        <Label
            id="rightChannelName"
            translation="[336, 24]"
            width="160"
            height="26"
            vertAlign="center"
            color="0xffffffff"
            font="font:SmallBoldSystemFont"
            wrap="false"
            maxLines="1" />

        <!-- HD chip — smaller font, slightly taller box so the "HD"
             glyph isn't cropped. Pinned to the top-right of the
             info column. -->
        <Rectangle
            id="hdChipBg"
            translation="[504, 26]"
            width="40"
            height="24"
            color="0xe5a00dff"
            visible="false" />
        <Label
            id="hdChipLabel"
            translation="[504, 26]"
            width="40"
            height="24"
            horizAlign="center"
            vertAlign="center"
            color="0x000000ff"
            text="HD"
            visible="false">
            <Font role="font" uri="font:SystemFontFile" size="16" />
        </Label>

        <!-- EPG block — two NOW + NEXT pairs. Small all-caps label,
             larger program title below. Labels + titles stay
             visually grouped via tight vertical spacing. Pale gold
             for now-playing, dim grey for next. Everything hidden
             when EPG data isn't available for this channel. -->
        <Label
            id="nowLabel"
            translation="[252, 68]"
            width="290"
            height="22"
            color="0xb0b0b0ff"
            text="NOW"
            visible="false">
            <Font role="font" uri="font:SystemFontFile" size="20" />
        </Label>
        <Label
            id="nowProgram"
            translation="[252, 92]"
            width="290"
            height="60"
            color="0xf5d87aff"
            wrap="true"
            maxLines="2"
            visible="false">
            <Font role="font" uri="font:SystemFontFile" size="24" />
        </Label>
        <Label
            id="nextLabel"
            translation="[252, 158]"
            width="290"
            height="20"
            color="0x808080ff"
            text="NEXT"
            visible="false">
            <Font role="font" uri="font:SystemFontFile" size="18" />
        </Label>
        <Label
            id="nextProgram"
            translation="[252, 180]"
            width="290"
            height="32"
            color="0xccccccff"
            wrap="false"
            maxLines="1"
            visible="false">
            <Font role="font" uri="font:SystemFontFile" size="22" />
        </Label>

        <!-- Focus ring (4 pale-gold strips, same pattern as PosterItem). -->
        <Rectangle id="focusRingTop" width="560" height="3" color="0xf5d87aff" visible="false" />
        <Rectangle id="focusRingBottom" translation="[0, 237]" width="560" height="3" color="0xf5d87aff" visible="false" />
        <Rectangle id="focusRingLeft" width="3" height="240" color="0xf5d87aff" visible="false" />
        <Rectangle id="focusRingRight" translation="[557, 0]" width="3" height="240" color="0xf5d87aff" visible="false" />
    </children>
</component>
